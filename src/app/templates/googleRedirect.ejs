<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ServiZen - Google Login</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            text-align: center;
            padding: 50px;
        }
        .loading {
            margin-top: 20px;
            font-size: 14px;
            color: #666;
        }
    </style>
</head>
<body>
    <h1>ServiZen</h1>
    <p>Redirecting to Google login...</p>
    <div class="loading">Please wait...</div>

    <script>
        function loginWithGoogle() {
            const callbackURL = '<%= callbackURL %>';
            const betterAuthUrl = '<%= betterAuthUrl %>';
            const signInEndpoint = `${betterAuthUrl}/api/auth/sign-in/social`;

            fetch(signInEndpoint, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                credentials: 'include',
                body: JSON.stringify({
                    provider: 'google',
                    callbackURL: callbackURL
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.url) {
                    window.location.href = data.url;
                } else {
                    document.querySelector('.loading').textContent = 'Error: Could not redirect to Google';
                }
            })
            .catch(error => {
                document.querySelector('.loading').textContent = 'Error: ' + error.message;
            });
        }

        // Auto redirect on page load
        window.onload = function() {
            loginWithGoogle();
        };
    </script>
</body>
</html>
